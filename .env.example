# Neon Postgres connection string (auto-injected by the Vercel Marketplace
# Neon integration in production; for local dev, run `vercel env pull .env.local`
# or copy your Neon connection string here manually).
DATABASE_URL=

# Passcode for the privacy gate (middleware). Pick anything you can remember.
ACCESS_CODE=

# Web Push VAPID keys — generate with `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Shared secret checked by /api/cron/reminder (set the same value in Vercel's
# Cron configuration / Authorization header).
CRON_SECRET=
